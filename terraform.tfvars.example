# =============================================================================
# Example terraform.tfvars
#
# Copy this file to terraform.tfvars and fill in your own values:
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored. Do NOT commit real values.
# Sensitive values (passwords, tokens) should be provided via TF_VAR_* env
# vars instead of this file — see the bottom of this template.
# =============================================================================

# ── GHCR / Image ─────────────────────────────────────────────────────────────
ghcr_username   = "your-github-username"
container_image = "ghcr.io/your-github-username/django-app:latest"

# ── Optional overrides (uncomment to change defaults) ────────────────────────
# project_name      = "django-aks"
# location          = "eastus2"
# aks_node_count    = 2
# aks_node_vm_size  = "Standard_B2s"
# app_replicas      = 2
# db_admin_username = "pgadmin"
# db_name           = "djangodb"

# =============================================================================
# Sensitive values — provide via environment variables, NOT this file:
#
#   export TF_VAR_db_admin_password='<strong-password>'
#   export TF_VAR_django_secret_key='<random-secret-key>'
#   export TF_VAR_ghcr_token='<github-pat-with-read:packages>'
# =============================================================================
